{
  "slug": "terminal",
  "name": "Terminal",
  "description": "Minimal Linux shell (xfce4-terminal) in a browser tab.",
  "version": "1.0",
  "category": "Development",
  "tags": [
    "terminal",
    "shell",
    "cli"
  ],
  "icon": "icon.svg",
  "docker_image": "flaskapp-workspace/terminal:1.0",
  "build_path": "apps/terminal",
  "status": "stable",
  "features": {
    "audio": true,
    "clipboard": true,
    "persistent": true,
    "downloads": true,
    "uploads": true
  },
  "defaults": {
    "cpu_cores": 1,
    "memory_mb": 1024,
    "disk_mb": 2048,
    "network_mode": "bridge",
    "persistent_profile": true,
    "startup_command": "xfce4-terminal",
    "allow_clipboard": true,
    "allow_upload": true,
    "allow_download": true,
    "allow_audio": true
  }
}
