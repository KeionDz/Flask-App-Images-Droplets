{
  "slug": "firefox",
  "name": "Firefox Browser",
  "description": "Mozilla Firefox in an isolated, disposable workspace.",
  "version": "1.0",
  "category": "Browser",
  "tags": [
    "browser",
    "web",
    "firefox"
  ],
  "icon": "icon.png",
  "docker_image": "flaskapp-workspace/firefox:1.0",
  "build_path": "apps/firefox",
  "status": "stable",
  "features": {
    "audio": true,
    "clipboard": true,
    "persistent": true,
    "downloads": true,
    "uploads": true
  },
  "defaults": {
    "cpu_cores": 1,
    "memory_mb": 2048,
    "disk_mb": 4096,
    "network_mode": "bridge",
    "persistent_profile": false,
    "startup_command": "firefox",
    "allow_clipboard": true,
    "allow_upload": true,
    "allow_download": true,
    "allow_audio": true
  }
}
