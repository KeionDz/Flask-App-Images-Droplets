{
  "slug": "libreoffice",
  "name": "LibreOffice",
  "description": "Full office suite \u2014 documents, spreadsheets, presentations.",
  "version": "1.0",
  "category": "Productivity",
  "tags": [
    "office",
    "documents",
    "productivity"
  ],
  "icon": "icon.svg",
  "docker_image": "flaskapp-workspace/libreoffice:1.0",
  "build_path": "apps/libreoffice",
  "status": "stable",
  "features": {
    "audio": true,
    "clipboard": true,
    "persistent": true,
    "downloads": true,
    "uploads": true
  },
  "defaults": {
    "cpu_cores": 2,
    "memory_mb": 4096,
    "disk_mb": 6144,
    "network_mode": "bridge",
    "persistent_profile": true,
    "startup_command": "libreoffice",
    "allow_clipboard": true,
    "allow_upload": true,
    "allow_download": true,
    "allow_audio": true
  }
}
